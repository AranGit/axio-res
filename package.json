{
  "name": "axio-res",
  "version": "1.0.0",
  "description": "A Result Monad wrapper for Axios — functional error handling, Zod validation, mocking, and state sync for React/Next.js.",
  "keywords": [
    "axios",
    "result",
    "monad",
    "error-handling",
    "zod",
    "react",
    "nextjs",
    "functional",
    "mock",
    "typescript"
  ],
  "author": "AranGit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AranGit/axio-res.git"
  },
  "homepage": "https://github.com/AranGit/axio-res#readme",
  "bugs": {
    "url": "https://github.com/AranGit/axio-res/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "axios": ">=1.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "axios": "^1.7.9",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  }
}
